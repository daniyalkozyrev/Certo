# ── Certo frontend environment ─────────────────────────────────────
# Copy to .env.local. The only required var is the backend API URL.

# Certo backend (FastAPI). The dashboard talks to this for all data.
NEXT_PUBLIC_API_URL=http://localhost:8000

# App URL (for share links / certificates / OG image)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Analytics — PostHog (optional; track() is a safe no-op without it)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
