# ── Secrets & local data (NEVER commit) ───────────────────────────
.env
.env.local
*.db
*.sqlite
*.sqlite3
backend/certo.db

# ── Python ─────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ── Node / Next.js (frontend) ──────────────────────────────────────
node_modules/
.next/
out/
build/
npm-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Editor / OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.log
.idea/
.vscode/

# Keep .env.example templates (they carry no secrets) — they are not matched
# by the `.env` rule above because the filename differs.

.vercel
.env*
