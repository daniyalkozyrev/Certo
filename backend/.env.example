# ─────────────────────────────────────────────────────────────
# Certo backend — environment configuration
# Copy to `.env` and fill in real values. Never commit `.env`.
# ─────────────────────────────────────────────────────────────

# App
ENV=local                       # local | staging | production
DEBUG=true
API_PREFIX=/api/v1

# CORS — origins your frontend runs on (comma-separated).
# Next.js/CRA -> 3000, Vite -> 5173. Add your prod domain when deployed.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (async driver: postgresql+asyncpg)
DATABASE_URL=postgresql+asyncpg://certo:certo@localhost:5432/certo

# Redis (Arq background worker)
REDIS_URL=redis://localhost:6379/0

# ── E2B sandbox ──────────────────────────────────────────────
E2B_API_KEY=                    # https://e2b.dev — leave empty to use MOCK_SANDBOX
MOCK_SANDBOX=true               # true: run code locally/stubbed instead of real E2B

# ── Judge #1: Prometheus 2 served via self-hosted vLLM ───────
# vLLM exposes an OpenAI-compatible API. Point this at the university GPU box.
JUDGE_BASE_URL=http://localhost:8000/v1
JUDGE_API_KEY=EMPTY             # vLLM ignores it but openai client requires a value
JUDGE_MODEL=prometheus-eval/prometheus-7b-v2.0
MOCK_JUDGE=true                 # true: deterministic stub score instead of real model

# ── Judge: Anthropic Claude (temporary primary while Prometheus GPU is down) ──
# Set ENABLED=true to grade with Claude instead of Prometheus-2.
# "Sonnet 3.5" is retired (404) -> claude-sonnet-4-6 is the drop-in successor.
JUDGE_ANTHROPIC_ENABLED=false
ANTHROPIC_API_KEY=
JUDGE_ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Judge #2: secondary LLM judge (ensemble, removes subjectivity) ──
# >>> PLUG IN ANOTHER LLM HERE <<<  Any OpenAI-compatible endpoint.
# Set ENABLED=true and fill in the 3 lines below to activate a 2-judge ensemble.
JUDGE_SECONDARY_ENABLED=false
JUDGE_SECONDARY_BASE_URL=https://api.openai.com/v1
JUDGE_SECONDARY_API_KEY=
JUDGE_SECONDARY_MODEL=gpt-4o-mini

# ── Agent-under-test default inference (can be overridden per-agent) ──
AGENT_DEFAULT_BASE_URL=https://api.openai.com/v1
AGENT_DEFAULT_API_KEY=
AGENT_DEFAULT_MODEL=gpt-4o-mini

# ── Scoring ──────────────────────────────────────────────────
REWARD_PASS_THRESHOLD=4         # judge score (1-5) >= threshold -> reward +1, else -1

# ── Auth ─────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production        # signs JWTs + login codes — set a long random value
ACCESS_TOKEN_DAYS=30
FRONTEND_URL=http://localhost:3000        # where Google OAuth redirects back to

# Login-code email delivery: "console" (dev: code printed in log + shown in UI) or "smtp"
EMAIL_MODE=console
EMAIL_FROM=Certo <no-reply@certo.local>
# Fill these in and set EMAIL_MODE=smtp to send real emails (e.g. Gmail app password):
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=true

# "Continue with Google" — create an OAuth client at console.cloud.google.com,
# add redirect URI:  http://localhost:8000/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
